<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Video player surface -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true" />

    <!-- Channel name overlay -->
    <TextView
        android:id="@+id/channel_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:textColor="#B3FFFFFF"
        android:textSize="14sp"
        android:shadowColor="#000000"
        android:shadowRadius="4" />

    <!-- Volume / brightness indicator -->
    <TextView
        android:id="@+id/indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#99000000"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:visibility="gone" />

    <!-- Left panel -->
    <LinearLayout
        android:id="@+id/left_panel"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#E61E1E1E"
        android:orientation="vertical"
        android:padding="8dp">

        <EditText
            android:id="@+id/search"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#1E1E1E"
            android:hint="@string/search_hint"
            android:textColor="#E0E0E0"
            android:textColorHint="#888888"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channel_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:scrollbars="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <Button
                android:id="@+id/btn_refresh"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:layout_marginRight="2dp"
                android:background="#0E639C"
                android:text="@string/refresh"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_source"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="2dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_marginRight="2dp"
                android:background="#0E639C"
                android:text="@string/switch_source"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_fav"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginLeft="2dp"
                android:layout_marginStart="2dp"
                android:background="#0E639C"
                android:text="@string/favorites"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#888888"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Hide/show panel button (top-left, same layer as lock) -->
    <Button
        android:id="@+id/btn_toggle_panel"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:background="#CC000000"
        android:text="◀"
        android:textColor="#E0E0E0"
        android:textSize="16sp" />

    <!-- Lock button (bottom-left, same layer as toggle) -->
    <Button
        android:id="@+id/btn_lock"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="8dp"
        android:background="#CC000000"
        android:text="🔓"
        android:textColor="#E0E0E0"
        android:textSize="16sp" />

</FrameLayout>
